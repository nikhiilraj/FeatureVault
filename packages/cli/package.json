{
  "name": "featurevault",
  "version": "0.1.0",
  "description": "FeatureVault CLI — manage feature flags from your terminal",
  "type": "module",
  "bin": {
    "fv": "./dist/index.js",
    "featurevault": "./dist/index.js"
  },
  "scripts": {
    "build":     "tsup",
    "dev":       "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "axios":          "^1.7.0",
    "chalk":          "^5.3.0",
    "conf":           "^13.0.0",
    "ora":            "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup":        "^8.0.0",
    "typescript":  "^5.4.0",
    "vitest":      "^1.6.0"
  },
  "engines": { "node": ">=18" },
  "files": ["dist"],
  "keywords": ["feature-flags", "cli", "featurevault", "ab-testing"],
  "license": "MIT"
}
