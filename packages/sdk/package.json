{
  "name": "featurevault-node",
  "version": "0.1.0",
  "description": "FeatureVault Node.js SDK — zero-network-call feature flag evaluation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "feature-flags",
    "ab-testing",
    "sdk",
    "featurevault"
  ],
  "license": "MIT",
  "dependencies": {
    "murmurhash": "^2.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@featurevault/shared": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
