{
  "name": "@featurevault/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.1",
    "argon2": "^0.40.1",
    "bullmq": "^5.7.0",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "nodemailer": "^6.10.1",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.21.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.11.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
