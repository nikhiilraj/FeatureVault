# Copy to .env and fill in values
# Database
DATABASE_URL=postgresql://featurevault:secret@localhost:5433/featurevault
# Redis
REDIS_URL=redis://localhost:6379
# JWT — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ISSUER=featurevault
# Email (Resend)
EMAIL_FROM=noreply@featurevault.dev
RESEND_API_KEY=re_your_api_key_here
# App
API_PORT=4000
WEB_PORT=3000
NODE_ENV=development
