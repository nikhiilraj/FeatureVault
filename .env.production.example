# ============================================================
# FeatureVault — Production Environment
# Copy to .env.production, fill in values, NEVER COMMIT
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=featurevault
POSTGRES_PASSWORD=           # min 32 random chars: openssl rand -hex 24
POSTGRES_DB=featurevault

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=              # min 32 random chars: openssl rand -hex 24

# ── App secrets ──────────────────────────────────────────────
# min 32 chars: openssl rand -hex 32
COOKIE_SECRET=

# ── URLs ─────────────────────────────────────────────────────
# These must match your domain and Nginx config
WEB_URL=https://featurevault.yourdomain.com
API_URL=https://featurevault.yourdomain.com
WS_URL=wss://featurevault.yourdomain.com
# ════════════════════════════════════════════════════════════════════════════════
# 5. Email (Resend)
# ════════════════════════════════════════════════════════════════════════════════

RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@featurevault.example.com
