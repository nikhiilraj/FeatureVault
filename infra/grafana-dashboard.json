{
  "title": "FeatureVault Engineering: Reliability & Algorithms",
  "tags": ["ATS-Optimized", "FAANG-Tier", "FeatureVault", "System Design"],
  "timezone": "browser",
  "panels": [
    {
      "type": "row",
      "title": "North Star & Delivery Mechanics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "API P95 Target Latency",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 18, "x": 0, "y": 1 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(fv_api_request_duration_seconds_bucket[5m])) by (le, route))", "legendFormat": "P95 {{route}}" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Active SDK Tunnels",
      "type": "stat",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 1 },
      "targets": [{ "expr": "sum(fv_ws_connections_active)", "legendFormat": "Connections" }],
      "fieldConfig": { "defaults": { "color": { "mode": "value" } } }
    },

    {
      "type": "row",
      "title": "Distributed Queues & Worker Telemetry",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }
    },
    {
      "title": "BullMQ Processing Deep-Queue",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 },
      "targets": [
        { "expr": "sum(fv_bullmq_jobs_waiting)", "legendFormat": "Job Backpressure (Waiting)" },
        { "expr": "sum(fv_bullmq_jobs_active)", "legendFormat": "Workers Threading (Active)" }
      ]
    },
    {
      "title": "BullMQ Operations Throughput",
      "type": "stat",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 },
      "targets": [{ "expr": "sum(rate(fv_events_queued_total[5m]))", "legendFormat": "BullMQ Inserts/sec" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "type": "row",
      "title": "Data Persistence Starvation & Caching Analytics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "title": "PostgreSQL Connection Starvation Limits",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 },
      "targets": [
        { "expr": "sum(fv_pg_pool_active_connections)", "legendFormat": "Active Connections" },
        { "expr": "sum(fv_pg_pool_idle_connections)", "legendFormat": "Idle Connections" },
        { "expr": "sum(fv_pg_pool_waiting_queries)", "legendFormat": "Waiting for Lock (Starvation!)" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Redis Pub/Sub Proxy Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 },
      "targets": [{ "expr": "sum(rate(fv_flag_cache_hits_total[5m])) / (sum(rate(fv_flag_cache_hits_total[5m])) + sum(rate(fv_flag_cache_misses_total[5m])))", "legendFormat": "Hit %" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "green", "value": 0.8 }] } } }
    },

    {
      "type": "row",
      "title": "Deterministic Algorithms & Security Defenses",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "title": "Mathematical Traffic Allocation Fairness (MurmurHash Verifier)",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 25 },
      "targets": [{ "expr": "increase(fv_experiment_allocations_total[1h])", "legendFormat": "Variant {{variant_id}}" }],
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "pieType": "donut" }
    },
    {
      "title": "Layer-7 Strict Authentication Security Drops",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 25 },
      "targets": [
        { "expr": "sum(increase(fv_rate_limit_exceeded_total[5m]))", "legendFormat": "Rate-Limit Blocking Triggered (429 Drops)" },
        { "expr": "sum(increase(fv_sdk_key_auth_failures_total[5m]))", "legendFormat": "Invalid/Revoked API Keys Dropped" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10 } } }
    }
  ],
  "schemaVersion": 38
}
